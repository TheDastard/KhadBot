# --- LLM Backend ---
# Set LLM_PROVIDER to one of: anthropic | openai | groq | ollama
#
# Provider guide:
#   anthropic — Claude Sonnet; best answer quality; use for quality eval runs
#   openai    — GPT-4o; alternative production model
#   groq      — Llama 3.3 70B, free tier; use for integration tests
#   ollama    — Local model (qwen3.5 recommended); use for inner dev loop (free)
#
# LLM Model is optional — each provider has a sensible default (see llm_factory.py).
# Override it here to pin a specific model version.

# LLM_PROVIDER=anthropic
# LLM_PROVIDER=openai
# LLM_PROVIDER=groq
LLM_PROVIDER=ollama

# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Anthropic default
# OPENAI_MODEL=gpt-4o                       # OpenAI default
# GROQ_MODEL=llama-3.3-70b-versatile        # Groq default
# GROQ_MODEL=llama-3.1-8b-instant           # Groq fast/cheap — scaffolding tests only
OLLAMA_MODEL=qwen3:8b                     # Ollama default (recommended for tool use)
# OLLAMA_MODEL=llama3.1                     # Ollama alternative

# --- API Keys ---
# Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your-openai-key-here

# Groq — free tier, sign up at https://console.groq.com
# GROQ_API_KEY=your-groq-key-here

# --- Ollama (local) ---
# Ollama runs on localhost by default. Override if running on a remote host.
# Requires: `ollama serve` running and model pulled: `ollama pull qwen2.5`
OLLAMA_BASE_URL=http://localhost:11434

# --- WarcraftLogs ---
WARCRAFTLOGS_CLIENT_ID=your-wcl-client-id
WARCRAFTLOGS_CLIENT_SECRET=your-wcl-client-secret

# --- Persona ---
# Set KHADBOT_PERSONA to one of: khadgar | thrall | xalatath
KHADBOT_PERSONA=khadgar

# --- LangSmith ---
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=your-langsmith-key-here
# LANGSMITH_PROJECT=KhadBot
